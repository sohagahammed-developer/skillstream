<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/backround_bg"
    android:layout_marginTop="-20dp"
    android:padding="10dp"
    tools:context=".Fragment.aboutUs">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:padding="20dp">

            <!-- App Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_skill_stream"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/Text_Color"
                android:layout_marginBottom="12dp"/>

            <!-- Card Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/backround_bg"
                android:elevation="16dp"
                android:padding="18dp">

                <!-- About Text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text='@string/skill_stream_is_an_app_based_platform_designed_to_streamline_online_learning_through_a_personalized_and_automated_approach_it_offers_features_such_as_customizable_learning_paths_auto_generated_study_materials_real_time_progress_tracking_and_course_recommendations_based_on_user_preferences_via_intelligent_algorithms'
                    android:textSize="15sp"
                    android:textColor="@color/DarkBlue"
                    android:lineSpacingExtra="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text='@string/these_tools_empower_learners_to_efficiently_achieve_their_educational_goals_the_platform_also_includes_study_schedule_reminders_progress_tracking_with_visual_graphs_and_reports_and_interactive_quizzes_to_enhance_the_learning_experience'
                    android:textSize="15sp"
                    android:textColor="@color/DarkBlue"
                    android:lineSpacingExtra="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text='@string/focused_on_accessibility_and_user_friendliness_skill_stream_provides_a_seamless_and_adaptable_experience_tailored_to_individual_learning_styles_and_needs'
                    android:textSize="15sp"
                    android:textColor="@color/DarkBlue"
                    android:lineSpacingExtra="6dp"/>

                <!-- Technology Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/technology_stack"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/Text_Color"
                    android:layout_marginTop="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/react_js_for_a_responsive_interface_n_node_js_for_robust_backend_operations_n_mongodb_for_scalable_data_management"
                    android:textSize="15sp"
                    android:textColor="@color/DarkBlue"
                    android:lineSpacingExtra="6dp"/>

                <!-- Future Plan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/future_enhancements"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/Text_Color"
                    android:layout_marginTop="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/live_tutoring_sessions_n_collaborative_study_groups_n_dedicated_mobile_application"
                    android:textSize="15sp"
                    android:textColor="@color/DarkBlue"
                    android:lineSpacingExtra="6dp"/>

            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empowering_learning_through_technology"
                android:textSize="13sp"
                android:textStyle="italic"
                android:textColor="@color/Text_Color"
                android:layout_marginTop="20dp"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>